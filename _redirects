# Netlify _redirects file for anjuredheendran.com
# Place this file in the ROOT of your Netlify deploy folder (same level as index.html)
# These 301 redirects fix old indexed URLs that are splitting your domain authority

/about-the-author       /about.html     301
/about-the-author/      /about.html     301
/books                  /index.html     301
/books/                 /index.html     301
/blogs                  /index.html     301
/blogs/                 /index.html     301

/tiktok                 https://anjuredheendran.com/start.html?utm_source=tiktok&utm_medium=social&utm_campaign=bio_link   301

# Amazon affiliate link redirects — fires a GA4 event client-side before
# redirecting to Amazon, so a plain server-side 301 won't work here (no JS
# would run). This rewrite keeps the URL as /go/whatever in the browser
# while serving go/index.html, which looks up the slug and handles it.
/go/*                   /go/index.html  200

# Catch-all: any unmatched URL goes to homepage (prevents 404s)
/*                      /index.html     200
